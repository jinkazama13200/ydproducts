PORT=8787
NODE_ENV=development
PRODUCT_API_BASE=https://yida-new-mgr-omnxqgbi-api.yznba.com
PRODUCT_ORIGIN=https://yida-new-mgr-y5cf7h6r.yznba.com
PRODUCT_TOKEN=PUT_YOUR_ITOKEN_HERE
INTERNAL_API_KEY=PUT_YOUR_INTERNAL_API_KEY_HERE
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_PAGES=20
RATE_WINDOW_MINUTES=5
CACHE_TTL_MS=15000
UPSTREAM_TIMEOUT_MS=15000
UPSTREAM_RETRIES=1
REQUESTS_PER_MINUTE=120
ENABLE_DEBUG_UPSTREAM=true

# === NEW: Reliability & Cache Configuration ===
# Directory for persistent API response cache (fallback when API fails)
CACHE_DIR=/tmp/yd-cache

# Max age for cached data (5 minutes default). When API fails, serves data up to this age.
CACHE_MAX_AGE_MS=300000

# === NEW: Retry Configuration ===
# Number of retry attempts for API calls (default: 5)
MAX_RETRIES=5

# Base delay for exponential backoff: 300ms, 600ms, 1200ms, 2400ms, 4800ms (default: 300)
BASE_RETRY_DELAY_MS=300

# === NEW: Timeout Configuration ===
# Timeout for paginated API calls (default: 45000 = 45 seconds)
PAGINATED_CALL_TIMEOUT_MS=45000

# === NEW: Circuit Breaker Configuration ===
# Number of consecutive failures before circuit breaker opens (default: 5)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# How long to wait before trying again after circuit breaker opens (default: 180000 = 3 minutes)
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=180000

# === NEW: Real-time Push Configuration ===
# Enable auto-poll and push via WebSocket (default: true)
PUSH_ENABLED=true

# How often to auto-fetch and push data to clients (default: 5000 = 5 seconds)
# Lower = more real-time but more API calls. Min: 2000
PUSH_INTERVAL_MS=5000
